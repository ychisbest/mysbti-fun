---
import SiteLayout from "../layouts/SiteLayout.astro";
import partnerLinks from "../../links.json";

type PartnerLink = {
  html: string;
};

const links = partnerLinks as PartnerLink[];
---

<SiteLayout
  title="友情链接 | mysbti.fun"
  description="mysbti.fun 收录的友情链接。"
>
  <main class="max-w-4xl mx-auto px-4 py-16">
    <a
      href="/"
      class="heading-font text-3xl tracking-tighter border-b-4 border-black inline-block mb-12"
    >
      MySBTI.Fun
    </a>

    <section>
      <p class="font-black uppercase text-sm tracking-[0.25em] text-gray-500 mb-3">
        Partner Links
      </p>
      <h1 class="heading-font text-5xl md:text-7xl leading-none mb-6">
        友情链接
      </h1>
      <p class="text-lg font-bold text-gray-700 mb-10">
        这里收录分配给 mysbti.fun 的外部合作链接。
      </p>

      <div class="space-y-5">
        {
          links.map((link, index) => (
            <article class="neo-brutal bg-white p-6">
              <p class="mb-3 text-xs font-black uppercase tracking-[0.18em] text-gray-500">
                Link {index + 1}
              </p>
              <div
                class="text-base leading-8 font-bold text-gray-800 [&_a]:underline [&_a]:decoration-[#00FF66] [&_a]:decoration-4 [&_a]:underline-offset-4"
                set:html={link.html}
              />
            </article>
          ))
        }
      </div>
    </section>
  </main>
</SiteLayout>

<style>
  .neo-brutal {
    border: 3px solid #000;
    box-shadow: 5px 5px 0 0 #000;
  }

  .heading-font {
    font-family: "Archivo Black", sans-serif;
  }
</style>
